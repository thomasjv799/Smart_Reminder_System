# Postgres connection — use the claude_rw (read) role from the homelab stack
DATABASE_URI=postgresql://claude_rw:password@localhost:5432/homelab

# Telegram Bot API — get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# How far ahead to look for expirations (days); default 30
REMINDER_DAYS=30
